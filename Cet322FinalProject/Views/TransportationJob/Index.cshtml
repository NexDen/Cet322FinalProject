@using Cet322FinalProject.Data.Entities
@model IEnumerable<TransportationJob>
@{
    ViewData["Title"] = "Jobs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <span class="page-title">Transportation Jobs</span>
    <a asp-action="Create" class="btn btn-primary btn-sm">New Job</a>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Order Date</th>
            <th>Delivery Date</th>
            <th>Driver</th>
            <th>Vehicle</th>
            <th>Commodity</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var job in Model)
        {
            <tr>
                <td>@job.OrderDate?.ToString("yyyy-MM-dd")</td>
                <td>@job.DeliveryDate?.ToString("yyyy-MM-dd")</td>
                <td>@job.Driver?.Name @job.Driver?.Surname</td>
                <td>@job.Vehicle?.PlateNo</td>
                <td>@job.CommodityType</td>
                <td>
                    @if (job.IsActive == true)
                    {
                        <span class="badge bg-success fw-normal">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary fw-normal">Inactive</span>
                    }
                </td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@job.Id" class="text-decoration-none me-3">Details</a>
                    <a asp-action="Edit" asp-route-id="@job.Id" class="text-decoration-none">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>
