@{
    ViewData["Title"] = "Login";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="d-flex flex-column gap-3" style="width: 100%; max-width: 360px; padding: 30px;">

        <h1 class="text-center" style="font-size: 4rem;">CeTransport</h1>

        <input id="UsernameEntry" type="text" class="form-control" placeholder="Username" />

        <input id="PasswordEntry" type="password" class="form-control" placeholder="Password" />

        <div class="d-flex align-items-center gap-2">
            <input id="RememberCheckbox" type="checkbox" class="form-check-input m-0" />
            <label for="RememberCheckbox" class="form-check-label">Remember Me</label>
        </div>

        <button type="button" class="btn btn-primary w-100">Login</button>

    </div>
</div>