@{
    ViewData["Title"] = "Home";
}

<div class="mb-4">
    <span class="page-title">Dashboard</span>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <a asp-controller="Driver" asp-action="Index" class="text-decoration-none text-dark">
            <div class="border rounded p-4">
                <div class="fw-semibold mb-1">Drivers</div>
                <div class="text-muted small">View and manage drivers</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Vehicle" asp-action="Index" class="text-decoration-none text-dark">
            <div class="border rounded p-4">
                <div class="fw-semibold mb-1">Vehicles</div>
                <div class="text-muted small">View and manage vehicles</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="TransportationJob" asp-action="Index" class="text-decoration-none text-dark">
            <div class="border rounded p-4">
                <div class="fw-semibold mb-1">Jobs</div>
                <div class="text-muted small">View and manage transportation jobs</div>
            </div>
        </a>
    </div>
</div>