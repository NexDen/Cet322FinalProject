@using Cet322FinalProject.Data.Entities
@model IEnumerable<Vehicle>
@{
    ViewData["Title"] = "Vehicles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <span class="page-title">Vehicles</span>
    <a asp-action="Create" class="btn btn-primary btn-sm">Add Vehicle</a>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Plate No</th>
            <th>Model</th>
            <th>Year</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var vehicle in Model)
        {
            <tr>
                <td>@vehicle.PlateNo</td>
                <td>@vehicle.Model</td>
                <td>@vehicle.ProductionYear</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@vehicle.Id" class="text-decoration-none me-3">Details</a>
                    <a asp-action="Edit" asp-route-id="@vehicle.Id" class="text-decoration-none">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>