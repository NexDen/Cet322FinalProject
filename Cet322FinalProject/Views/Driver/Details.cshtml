@using Cet322FinalProject.Data.Entities
@model Driver
@{
    ViewData["Title"] = "Driver Details";
}

<div class="mb-4">
    <span class="page-title">Driver Details</span>
</div>

<table class="table table-bordered w-auto mb-4">
    <tbody>
        <tr>
            <th class="text-muted">Name</th>
            <td>@Model.Name @Model.Surname</td>
        </tr>
    </tbody>
</table>

<div class="mb-2 fw-semibold small text-muted text-uppercase" style="letter-spacing:.04em">License Document</div>
@if (Model.License != null && !string.IsNullOrEmpty(Model.License.FilePath))
{
    <p class="mb-1 text-muted small">Uploaded @Model.License.CreatedDate.ToString("yyyy-MM-dd")</p>
    <a href="@Model.License.FilePath" target="_blank" class="btn btn-outline-secondary btn-sm mb-4">View Document</a>
}
else
{
    <p class="text-muted small mb-4">No license document uploaded.</p>
}

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
</div>